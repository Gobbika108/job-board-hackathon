# MongoDB Atlas URI (get from your Atlas cluster)
ATLAS_URI=mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/jobboard?retryWrites=true&w=majority

# Or use local MongoDB
# MONGO_URI=mongodb://localhost:27017/jobboard

# JWT Secret (change this in production)
JWT_SECRET=your-super-secret-key-change-in-production

# Server Port
PORT=5000